لمرنة في فروع لوكاس المختلفة.':'Monthly and annual flexible hour packages across Locus branches.'}\u003c/p\u003e\u003cbutton class=\\\"btn btnPrimary\\\" data-go=\\\"packages\\\"\u003e${txt('details')}\u003c/button\u003e\u003c/article\u003e\u003c/div\u003e\u003c/div\u003e\u003c/section\u003e`)}\\nfunction privatePage(){const groups=[txt('all'),...new Set(DATA.branches.map(b=\u003ear()?b.groupAr:b.groupEn))];return pageShell(`\u003csection class=\\\"serviceHero\\\"\u003e\u003cdiv class=\\\"container\\\"\u003e${titleBlock('Locus Private Offices',ar()?'غرف إدارية خاصة':'Private Offices',ar()?'لتفاصيل الصور والأسعار اختار الفرع المطلوب من هنا.':'Choose the branch to view photos and prices.')}\u003cdiv class=\\\"branchToolbar reveal\\\"\u003e\u003cdiv class=\\\"searchBox\\\"\u003e\u003cspan\u003e🔎\u003c/span\u003e\u003cinput id=\\\"branchSearch\\\" placeholder=\\\"${txt('searchBranch')}\\\"\u003e\u003c/div\u003e\u003cdiv class=\\\"chips\\\" id=\\\"groupFilters\\\"\u003e${groups.map((g,i)=\u003e`\u003cbutton class=\\\"chip ${i==0?'blue':''}\\\" data-filter=\\\"${g}\\\"\u003e${g}\u003c/button\u003e`).join('')}\u003c/div\u003e\u003c/div\u003e\u003cdiv class=\\\"branchGrid\\\" id=\\\"branchGrid\\\"\u003e${DATA.branches.map(branchCard).join('')}\u003c/div\u003e\u003c/div\u003e\u003c/section\u003e`)}\\nfunction branchCard(b){return `\u003carticle class=\\\"branchCard reveal\\\" data-name=\\\"${(b.nameAr+' '+b.districtAr+' '+b.nameEn+' '+b.districtEn).toLowerCase()}\\\" data-group=\\\"${ar()?b.groupAr:b.groupEn}\\\"\u003e\u003cimg class=\\\"branchImg\\\" loading=\\\"lazy\\\" src=\\\"${A['br_'+b.id]}\\\" alt=\\\"${ar()?b.nameAr:b.nameEn}\\\"\u003e\u003cdiv class=\\\"branchBody\\\"\u003e\u003ch3\u003e${ar()?b.nameAr:b.nameEn}\u003c/h3\u003e\u003cdiv class=\\\"branchMeta\\\"\u003e📍 ${ar()?b.districtAr:b.districtEn}\u003cbr\u003e${txt('from')} ${money(minPrice(b))} ${txt('perMonth')}\u003c/div\u003e\u003cdiv class=\\\"branchActions\\\"\u003e\u003cbutton class=\\\"btn btnPrimary\\\"