th)\\n    yy = y\\n    lh = text_size('سطر', fnt)[1] + line_spacing\\n    for line in lines:\\n        d.text((x_right, yy), line, font=fnt, fill=fill, direction='rtl', anchor='ra')\\n        yy += lh\\n    return yy\\n\\ndef draw_center(text, x, y, fnt, fill=TEXT):\\n    d.text((x,y), text, font=fnt, fill=fill, direction='rtl', anchor='mm')\\n\\ndef wrap_rtl(text, fnt, max_width):\\n    words = text.split()\\n    lines=[]\\n    cur=''\\n    for w in words:\\n        cand = (cur + ' ' + w).strip()\\n        if text_size(cand, fnt)[0] \u003c= max_width or not cur:\\n            cur=cand\\n        else:\\n            lines.append(cur)\\n            cur=w\\n    if cur:\\n        lines.append(cur)\\n    return lines\\n\\ndef draw_pill(text, x_right, y, fnt, fill, txt=WHITE, pad_x=18, pad_y=6):\\n    w,h = text_size(text, fnt)\\n    x1 = x_right - w - pad_x*2\\n    y1 = y\\n    x2 = x_right\\n    y2 = y + h + pad_y*2\\n    d.rounded_rectangle((x1,y1,x2,y2), radius=18, fill=fill)\\n    d.text((x_right-pad_x, y1+pad_y+h/2), text, font=fnt, fill=txt, direction='rtl', anchor='rm')\\n    return (x1,y1,x2,y2)\\n\\ndef draw_bullets(items, x_right, y, width, fnt=f_body, fill=TEXT, dot_color=BLUE, gap=14, line_spacing=6):\\n    yy=y\\n    for item in items:\\n        # wrap text with bullet gutter\\n        lines = wrap_rtl(item, fnt, width-34)\\n        lh = text_size('سطر', fnt)[1] + line_spacing\\n        d.ellipse((x_right-14, yy+7, x_right-4, yy+17), fill=dot_color)\\n        for line in lines:\\n            d.text((x_right-34, yy), line, font=fnt, fill=fill, direction='rtl', anchor='ra')\\n            yy += lh\\n        yy += gap\\n    return yy\\n\\n# Header background\\nfor y in range(0, 360):\\n    t = y/360\\n    col = tuple(int(NAVY[i]*(1-t) + NAVY2[i]*t) for i in range(3))\\n    d.line((0,y,W,y), fill=col)\\n# Decorative shapes\\nfor cx,cy,r,alpha in [(130,80,90,40),(1480,120,140,35),(1280,320,70,35)]:\\n    layer=Image.new('RGBA',(W,H),(0,0,0,0)); ld=ImageDraw.Draw(l