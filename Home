al\\\"\u003e\u003cdiv\u003e\u003ch1\u003e${ar()?'ابدأ شركتك دلوقتي':'Start your business now'}\u003c/h1\u003e\u003cp\u003e${ar()?'تعاقد أونلاين أو من أقرب فرع ليك. فريق المبيعات يساعدك تختار الخدمة الأنسب حسب نشاطك وميزانيتك.':'Contract online or from the nearest branch. Our sales team helps you choose the right solution.'}\u003c/p\u003e\u003cdiv class=\\\"actions\\\"\u003e\u003ca class=\\\"btn btnPrimary\\\" href=\\\"tel:${salesPhone}\\\"\u003e☎ ${txt('contactNow')}\u003c/a\u003e\u003ca class=\\\"btn btnGhost\\\" href=\\\"${customerWhats}\\\" target=\\\"_blank\\\"\u003eWhatsApp\u003c/a\u003e\u003c/div\u003e\u003c/div\u003e\u003cdiv class=\\\"featureGrid\\\"\u003e\u003cdiv class=\\\"feature\\\"\u003e\u003cb\u003e✓\u003c/b\u003e${ar()?'شركة موثوقة':'Trusted'}\u003c/div\u003e\u003cdiv class=\\\"feature\\\"\u003e\u003cb\u003e23+\u003c/b\u003e${ar()?'فرع':'Branches'}\u003c/div\u003e\u003cdiv class=\\\"feature\\\"\u003e\u003cb\u003e10K+\u003c/b\u003e${ar()?'عميل':'Clients'}\u003c/div\u003e\u003cdiv class=\\\"feature\\\"\u003e\u003cb\u003e⚡\u003c/b\u003e${ar()?'تنفيذ سريع':'Fast setup'}\u003c/div\u003e\u003c/div\u003e\u003c/div\u003e\u003c/div\u003e\u003c/section\u003e`}\\nfunction servicesPage(){return pageShell(`\u003csection class=\\\"serviceHero\\\"\u003e\u003cdiv class=\\\"container\\\"\u003e${titleBlock(ar()?'اختار رحلتك':'Choose your journey',ar()?'خدماتنا':'Our Services',ar()?'كل خدمة مصممة علشان تحل مشكلة فعلية وتساعدك تتحرك أسرع وبشكل منظم.':'Every service is designed to solve a real business problem and help you move faster.')}\u003cdiv class=\\\"cards\\\"\u003e${DATA.services.map(serviceCard).join('')}\u003c/div\u003e\u003c/div\u003e\u003c/section\u003e${finalCTA()}`)}\\nfunction adminPage(){return pageShell(`\u003csection class=\\\"serviceHero\\\"\u003e\u003cdiv class=\\\"container\\\"\u003e\u003cdiv class=\\\"heroMini reveal\\\"\u003e\u003cdiv\u003e\u003cdiv class=\\\"eyebrow\\\"\u003e${ar()?'خدمات المقر الإداري':'Business address services'}\u003c/div\u003e\