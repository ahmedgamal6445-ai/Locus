function recruitmentPage(){return detailPage({route:'recruitment-service',ey:'Recruitment',title:t('recruitment'),sub:ar()?'حل توظيف سنوي يساعدك توصل للموظفين المناسبين':'Annual recruitment solution for suitable employees',img:A.recruitmentPoster,lead:ar()?'الخدمة مناسبة للشركات والمصانع والمولات والمحلات، وتشمل الإعلان والفرز والمقابلات الأولية وترشيح أفضل المرشحين.':'Suitable for companies, factories, malls and stores. Includes ads, filtering, initial interviews and shortlisting.',features:ar()?['إعلان احترافي للوظيفة','فرز المتقدمين بدقة','مقابلات أولية Interview','ترشيح أفضل المرشحين','توفير وقت ومجهود الإدارة','تعاقد قانوني واضح','السعر 4,999 جنيه سنوياً']:['Professional job ad','Accurate applicant filtering','Initial interviews','Best candidate shortlisting','Saves management time','Clear legal contract','Price: EGP 4,999 annually']})}
function stepsBlock(arSteps,enSteps){let arr=ar()?arSteps:enSteps;return `<div class="stepper">${arr.map((s,i)=>`<div class="step reveal"><b>${i+1}</b><div>${s}</div></div>`).join('')}</div>`}
function detailPage(o){return `<section class="pageHero"><div class="container">${crumbs(o.title)}<div class="serviceHero"><div class="panel reveal"><div class="eyebrow">${o.ey}</div><h1 class="pageTitle">${o.title}</h1><h2 style="margin:0 0 12px;color:var(--blue)">${o.sub}</h2><p class="muted" style="font-size:18px">${o.lead}</p><div class="featureList">${o.features.map(f=>`<div class="feature">${icon('check')}<span>${f}</span></div>`).join('')}</div><div class="ctaRow"><a class="btn primary pulse" href="tel:01551585877">${t('call')}</a><a class="btn ghost" href="https://wa.link/7bq321" target="_blank">${t('whatsapp')}</a></div>${share()}</div><div class="visualPanel reveal"><img src="${o.img}" alt="${o.title}" loading="lazy"></div></div>${o.extra?`<div class="section"><div class="container">${o.extra}</div></div>`:''}</div></section>`}
function aboutPage(){return `<section class="pageHero"><div class="container">${crumbs(t('about'))}<div class="split"><div class="panel reveal"><div class="eyebrow">Locus Space</div><h1 class="pageTitle">${t('about')}</h1><div class="aboutText"><p>${ar()?'هي شركة مصرية تقدم مجموعة من الحلول الإدارية والقانونية والتسويقية وتوفير مساحات مكتبية مجهزة بالكامل ومقرات إدارية للشركات الناشئة ورجال الأعمال والشركات الصغيرة لبدء مشاريعهم من اليوم الأول.':'An Egyptian company providing administrative, legal and marketing solutions, fully equipped office spaces and business addresses for startups, entrepreneurs and small companies.'}</p><p>${ar()?'تأسست الشركة عام 2016 لمديرها التنفيذي ومؤسسها الدكتور أحمد جمال.':'Founded in 2016 by CEO and founder Dr. Ahmed Gamal.'}</p><p>${ar()?'تتواجد الآن في مناطق مختلفة ومتميزة في القاهرة والجيزة والإسكندرية وتسعى إلى زيادة تواجدها في مناطق أخرى لمساعدة الشركات الناشئة في بدء مشاريعها.':'Locus operates in prime areas across Cairo, Giza and Alexandria and continues to expand.'}</p><p>${ar()?'توفر لوكاس مساحات مكتبية وغرف اجتماعات عالية الجودة وحلول أعمال أخرى مصممة لتلبية المتطلبات المهنية للشركات الناشئة وميزانياتها الريادية، مع ضمان خدمة إدارية شاملة.':'Locus provides office spaces, meeting rooms and business solutions designed for professional startup requirements and entrepreneurial budgets.'}</p><p>${ar()?'دائماً Locus حريصة على خلق بيئة تعاونية ونستمر في بناء ثقافة مهنية ودية حيث يمكن لعملائنا الازدهار والابتكار والنجاح.':'Locus is committed to building a collaborative and friendly professional culture where clients can grow, innovate and succeed.'}</p></div></div><div class="imageFrame reveal"><img src="${A.heroB}" loading="lazy"></div></div><div class="section">${head('',ar()?'خدمات لوكاس المتكاملة':'Integrated Locus Services','')}<div class="cards">${SV.map(serviceCard).join('')}</div></div>${share()}</div></section>`}
function contactPage(){return `<section class="pageHero"><div class="container">${crumbs(t('contact'))}${head('Contact',t('contact'),ar()?'اختر طريقة التواصل المناسبة.':'Choose the right contact method.')}<div class="contactGrid"><article class="card contactCard reveal"><div class="cardIcon" style="margin:auto auto 18px">${icon('phone')}</div><h3>${ar()?'المبيعات':'Sales'}</h3><p>${t('workingSales')}</p><a class="btn primary" href="tel:01551585877">${ar()?'اتصل من هنا':'Call now'}</a></article><article class="card contactCard reveal"><div class="cardIcon" style="margin:auto auto 18px">💬</div><h3>${ar()?'خدمة العملاء':'Customer Service'}</h3><p>${t('workingCS')}</p><a class="btn primary" href="https://wa.link/7bq321" target="_blank">${ar()?'تواصل من هنا':'Chat now'}</a></article><article class="card contactCard reveal"><div class="cardIcon" style="margin:auto auto 18px">${icon('map')}</div><h3>${ar()?'لوكيشن الفروع':'Branch locations'}</h3><p>${t('workingSales')}</p><a class="btn primary" href="${pageUrl('branch-locations')}">${ar()?'العناوين من هنا':'View locations'}</a></article></div>${share()}</div></section>`}
function locationsPage(){const groups=[...new Set(BR.map(group))];return `<section class="pageHero"><div class="container">${crumbs(t('locations'))}${head('Locations',t('locations'),ar()?'اضغط على اسم الفرع لفتح اللوكيشن مباشرة.':'Tap a branch to open location directly.')}<div class="locationGroups">${groups.map(g=>`<div class="panel reveal"><h2>${g}</h2><div class="locButtons">${BR.filter(b=>group(b)===g).map(b=>`<a class="locBtn" target="_blank" href="${b.map}">📍 ${name(b)}</a>`).join('')}</div></div>`).join('')}</div>${share()}</div></section>`}
function updateMeta(p,id){const titles={home:ar()?'حلول إدارية ومكتبية متكاملة للشركات':'Integrated Business and Office Solutions',services:t('services'),admin:t('admin'),'private-offices':ar()?'الغرف الإدارية بنظام الإيجار الشهري':'Private Offices','virtual-office':t('virtual'),packages:t('packages'),'company-formation':t('formation'),'accounting-service':t('accounting'),'website-service':t('website'),'marketing-system':t('marketing'),'recruitment-service':t('recruitment'),about:t('about'),contact:t('contact'),'branch-locations':t('locations')};let title=titles[p]||titles.home;if(p==='branch'){const b=BR.find(x=>x.id===id);if(b)title=name(b)}const desc=ar()?`${title} من Locus Space — حلول احترافية للشركات ورواد الأعمال بخبرة منذ 2016 وعبر أكثر من 23 فرع.`:`${title} by Locus Space — professional business solutions since 2016 across more than 23 branches.`;document.title=`${title} | Locus Space`;document.querySelector('meta[name="description"]')?.setAttribute('content',desc);document.querySelector('meta[property="og:title"]')?.setAttribute('content',document.title);document.querySelector('meta[property="og:description"]')?.setAttribute('content',desc);document.querySelector('meta[name="twitter:title"]')?.setAttribute('content',document.title);document.querySelector('meta[name="twitter:description"]')?.setAttribute('content',desc)}
function route(scroll=true){let p=document.body.dataset.page||'home';let id=document.body.dataset.id||'';updateMeta(p,id);let pages={home,services:servicesPage,admin:adminPage,'private-offices':privatePage,'virtual-office':virtualPage,packages:packagesPage,'company-formation':formationPage,'accounting-service':accountingPage,'website-service':websitePage,'marketing-system':marketingPage,'recruitment-service':recruitmentPage,about:aboutPage,contact:contactPage,'branch-locations':locationsPage};let pageHtml=p==='branch'?branchPage(id):(pages[p]||home)();document.getElementById('app').innerHTML=pageHtml;document.querySelectorAll('[data-nav]').forEach(n=>n.classList.toggle('active',n.dataset.nav===p));bind();filterInit();if(scroll)window.scrollTo({top:0,behavior:'smooth'});}
function filterInit(){let input=document.getElementById('branchSearch');if(!input)return;let doFilter=()=>{let q=input.value.toLowerCase();let f=document.querySelector('.tab.active')?.dataset.filter||t('all');document.querySelectorAll('.branchCard').forEach(c=>{let okq=c.dataset.name.includes(q), okf=f===t('all')||c.dataset.group===f;c.style.display=okq&&okf?'block':'none';});};input.oninput=doFilter;document.querySelectorAll('.tab').forEach(tab=>tab.onclick=()=>{document.querySelectorAll('.tab').forEach(x=>x.classList.remove('active'));tab.classList.add('active');doFilter();});}
function observe(){let io=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('show')}),{threshold:.06});document.querySelectorAll('.reveal').forEach(el=>io.observe(el));}
document.getElementById('openMenu').onclick=()=>{document.getElementById('mobileMenu').classList.add('open');document.body.classList.add('lock')};document.getElementById('closeMenu').onclick=closeMenu;document.getElementById('themeBtn').onclick=()=>setTheme(theme==='light'?'dark':'light');document.getElementById('mTheme').onclick=()=>setTheme(theme==='light'?'dark':'light');document.getElementById('langBtn').onclick=()=>setLang(ar()?'en':'ar');document.getElementById('mLang').onclick=()=>setLang(ar()?'en':'ar');
setTheme(theme);renderStatic();route(false);setTimeout(()=>document.getElementById('loader').classList.add('hide'),700);window.addEventListener('load',()=>setTimeout(()=>document.getElementById('loader').classList.add('hide'),120));
document.getElementById('schema').textContent=JSON.stringify({"@context":"https://schema.org","@type":"LocalBusiness","name":"Locus Space","url":"https://locus-office.com/","telephone":"01551585877","foundingDate":"2016","areaServed":"Egypt","sameAs":["https://www.facebook.com/share/1VbKjkN8VD/?mibextid=wwXIfr","https://www.instagram.com/locus.office.space","https://www.linkedin.com/company/locus-space/"],"department":SV.map(s=>({"@type":"Service","name":s.en,"description":s.descEn}))});
</script>
